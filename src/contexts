import React, { createContext, useState, useEffect, useCallback } from 'react';
import PropTypes from 'prop-types';

export const ProductContext = createContext();

export const ProductProvider = ({ children }) => {
  const [products, setProducts] = useState([]);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState(null);
  const [successMessage, setSuccessMessage] = useState('');

  const clearMessages = useCallback(() => {
    setError(null);
    setSuccessMessage('');
  }, []);

  const fetchProducts = useCallback(async () => {
    setIsLoading(true);
    clearMessages();
    try {
      const response = await fetch('https://fakestoreapi.com/products');
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      const data = await response.json();
      const adaptedProducts = data.map(p => ({
        id: p.id,
        name: p.title,
        description: p.description,
        price: parseFloat(p.price), // Ensure price is a number
        imageUrl: p.image,
        // Add a category if not present, or use p.category
        category: p.category || 'Uncategorized',
      }));
      setProducts(adaptedProducts);
    } catch (e) {
      setError(`Failed to fetch products: ${e.message}`);
      console.error("Failed to fetch products:", e);
    } finally {
      setIsLoading(false);
    }
  }, [clearMessages]);

  useEffect(() => {
    fetchProducts();
  }, [fetchProducts]);

  const addProduct = useCallback(async (productData) => {
    setIsLoading(true);
    clearMessages();
    // Simulate API call
    try {
      // In a real API, you would POST productData and get back the new product with an ID
      // For fakestoreapi (read-only), we simulate by adding to local state
      // Generate a temporary ID (in a real scenario, backend provides this)
      const newId = products.length > 0 ? Math.max(...products.map(p => p.id)) + 1 : 1;
      // Ensure the ID is not conflicting if products might not be sorted or have gaps.
      // A more robust temp ID could be `Date.now()` or a UUID.
      // const newId = Date.now();

      const newProduct = {
        ...productData,
        id: newId,
        // Simulate image if not provided, or use a default
        imageUrl: productData.imageUrl || 'https://via.placeholder.com/150'
      };

      setProducts(prevProducts => [newProduct, ...prevProducts]);
      setSuccessMessage('Producto agregado exitosamente.');
      // Simulate a delay
      // await new Promise(resolve => setTimeout(resolve, 500));
      return newProduct;
    } catch (e) {
      setError(`Error adding product: ${e.message}`);
      console.error("Error adding product:", e);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, [products, clearMessages]);

  const editProduct = useCallback(async (productId, updatedData) => {
    setIsLoading(true);
    clearMessages();
    // Simulate API call
    try {
      setProducts(prevProducts =>
        prevProducts.map(p => (p.id === productId ? { ...p, ...updatedData } : p))
      );
      setSuccessMessage('Producto actualizado exitosamente.');
      // Simulate a delay
      // await new Promise(resolve => setTimeout(resolve, 500));
      const updatedProduct = products.find(p => p.id === productId);
      return { ...updatedProduct, ...updatedData };
    } catch (e) {
      setError(`Error updating product: ${e.message}`);
      console.error("Error updating product:", e);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, [products, clearMessages]);

  const deleteProduct = useCallback(async (productId) => {
    setIsLoading(true);
    clearMessages();
    // Simulate API call
    try {
      setProducts(prevProducts => prevProducts.filter(p => p.id !== productId));
      setSuccessMessage('Producto eliminado exitosamente.');
      // Simulate a delay
      // await new Promise(resolve => setTimeout(resolve, 500));
      return true;
    } catch (e) {
      setError(`Error deleting product: ${e.message}`);
      console.error("Error deleting product:", e);
      return false;
    } finally {
      setIsLoading(false);
    }
  }, [clearMessages]);

  // Clear success/error messages after a delay
  useEffect(() => {
    if (successMessage || error) {
      const timer = setTimeout(() => {
        clearMessages();
      }, 3000); // Clear messages after 3 seconds
      return () => clearTimeout(timer);
    }
  }, [successMessage, error, clearMessages]);


  return (
    <ProductContext.Provider
      value={{
        products,
        isLoading,
        error,
        successMessage,
        fetchProducts,
        addProduct,
        editProduct,
        deleteProduct,
        clearMessages,
      }}
    >
      {children}
    </ProductContext.Provider>
  );
};

ProductProvider.propTypes = {
  children: PropTypes.node.isRequired,
};
